AFTER (Atomic Audit - GOOD):

choice ExecuteAtomicSettlement : AuditedSettlementResult
  controller assetIssuer
  do
    -- Settlement happens
    archive buyerPaymentCid
    archive sellerAssetCid
    newBuyerHolding <- create ...
    newSellerHolding <- create ...
    
    -- ✅ SOLUTION: Regulator view in SAME transaction
    regulatorView <- create RegulatorView with ...
    
