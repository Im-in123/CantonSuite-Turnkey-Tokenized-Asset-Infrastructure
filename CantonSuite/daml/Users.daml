-- | Users - User profiles and roles
module Users where

import Types

template User
  with
    partyId : Party
    name    : Text
    email   : Text
    role    : Role
  where
    signatory partyId
    
    choice UpdateProfile : ContractId User
      with
        newName  : Text
        newEmail : Text
      controller partyId
      do
        create this with
          name = newName
          email = newEmail
