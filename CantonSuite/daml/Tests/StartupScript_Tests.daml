-- | Tests/StartupScript_Tests.daml
-- THE ULTIMATE MASTER TEST (100% COVERAGE VALIDATION)

module Tests.StartupScript_Tests where

import Daml.Script
import DA.Assert
import DA.List (head)

import Scripts.StartupScript

-- Imports for Validation
import Portfolio
import Lending.Deposits (LenderShare)
import Finance.Instruments
import Marketplace.MultiTier qualified as MP
import Lending.PoolDiscovery qualified as PD

testUltimateInfrastructure : Script ()
testUltimateInfrastructure = script do
  debug "🚀 STARTING ULTIMATE PLATINUM TEST (100% COVERAGE)"

  -- 1. Execute the full triggers
  setup <- runCompleteStartupDemo

  -- 2. Validate Phase 8 (Price Update)
  allInstruments <- query @RWAInstrument setup.issuer
  let propertyTokens = filter (\(_, instrument) -> instrument.name == "NYC Plaza") allInstruments
  assertMsg "NYC Property instrument not found" (not (null propertyTokens))
  let (_, bondData) = head propertyTokens
  bondData.pricePerUnit === 1100.0
  debug "✅ VALIDATION: Asset Maintenance (UpdatePrice) verified."

  -- 3. Validate Global Marketplace Discovery (Public Party)
  listings <- queryFilter @MP.GlobalDiscoveryListing setup.publicMarket (\l -> l.listingId == "G-001")
  assertMsg "Public Market cannot see the global marketplace listing" (not (null listings))
  debug "✅ VALIDATION: Marketplace Discovery (publicParty) verified."

  -- 4. Validate Global Lending Discovery (Public Party)
  -- This proves the billboard pattern for Lending is working
  publicLendingListings <- queryFilter @PD.GlobalPoolDiscovery setup.publicMarket (\l -> l.listingId == "G-POOL-001")
  assertMsg "Public Market cannot see the global lending pool listing" (not (null publicLendingListings))
  debug "✅ VALIDATION: Lending Discovery (publicParty) verified."

  -- 5. Validate Firm/Restricted access (Charlie's Shares)
  charlieShares <- query @LenderShare setup.charlie
  assertMsg "Charlie shares missing" (not (null charlieShares))
  debug "✅ VALIDATION: Restricted Pool Access (Tier 2/3) verified."

  -- 6. Validate Default & Liquidation
  bankHoldings <- query @Holding_Impl setup.bank
  let seized = filter (\(_, payload) -> payload.assetId == "NYC-TOWER") bankHoldings
  assertMsg "Bank did not receive seized collateral after default" (not (null seized))
  debug "✅ VALIDATION: Secured Default & Liquidation verified."

  debug "🏁 ALL 100% COVERAGE VALIDATIONS PASSED. SYSTEM IS FULLY CONSISTENT."